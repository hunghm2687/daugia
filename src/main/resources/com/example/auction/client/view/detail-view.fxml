<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.DetailController"
            style="-fx-font-family: 'Arial'; -fx-font-size: 12;">

    <!-- Top: Back button -->
    <top>
        <HBox style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <Button fx:id="backBtn"
                    text="← Quay lại"
                    style="-fx-padding: 8 15; -fx-font-size: 12; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Center: Auction details -->
    <center>
        <HBox spacing="30" style="-fx-padding: 20; -fx-alignment: TOP_LEFT;">
            <!-- Left: Image -->
            <ImageView fx:id="itemImage"
                       fitWidth="350"
                       fitHeight="350"
                       preserveRatio="true"
                       style="-fx-border-color: #ddd; -fx-border-width: 1;"/>

            <!-- Right: Details -->
            <VBox spacing="15" style="-fx-padding: 0;">
                <Label fx:id="itemName"
                       text="Tên sản phẩm"
                       style="-fx-font-size: 24; -fx-font-weight: bold;"/>

                <VBox fx:id="infoVBox" spacing="10">
                    <Label fx:id="startPrice"
                           text="Giá khởi điểm: 0 đ"
                           style="-fx-font-size: 14;"/>

                    <Label fx:id="currentBid"
                           text="Giá cao nhất: 0 đ"
                           style="-fx-font-size: 14; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>

                    <Label fx:id="currentBidder"
                           text="Người đặt: -"
                           style="-fx-font-size: 12;"/>

                    <Label fx:id="seller"
                           text="Người bán: -"
                           style="-fx-font-size: 12;"/>

                    <Label fx:id="status"
                           text="Trạng thái: PENDING"
                           style="-fx-font-size: 12;"/>

                    <Label fx:id="startTime"
                           text="Thời gian bắt đầu: -"
                           style="-fx-font-size: 11;"/>

                    <Label fx:id="endTime"
                           text="Thời gian kết thúc: -"
                           style="-fx-font-size: 11;"/>

                    <Label fx:id="countDown"
                           text="Thời gian còn lại: -"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                </VBox>

                <!-- Bid Section -->
                <VBox spacing="10" style="-fx-border-color: #ddd; -fx-border-width: 1; -fx-padding: 15; -fx-border-radius: 5;">
                    <Label text="Đặt Giá"
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>

                    <TextField fx:id="bidAmount"
                               promptText="Nhập số tiền"
                               style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>

                    <Button fx:id="placeBidBtn"
                            text="Đặt Giá"
                            style="-fx-padding: 12; -fx-font-size: 14; -fx-cursor: hand; -fx-text-fill: white; -fx-background-color: #e74c3c; -fx-border-radius: 5;"/>

                    <Label fx:id="messageLabel"
                           text=""
                           style="-fx-text-fill: red; -fx-font-size: 11;"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>