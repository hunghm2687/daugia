<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.LoginController">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 50;">

            <Label text="🔐 ĐĂNG NHẬP"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <Separator/>

            <!-- Email -->
            <VBox spacing="5">
                <Label text="📧 Email:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="emailTextField"
                           promptText="Nhập email của bạn"
                           prefWidth="300"
                           prefHeight="35"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
                <Label text="🔑 Mật khẩu:" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Nhập mật khẩu (tối thiểu 6 ký tự)"
                               prefWidth="300"
                               prefHeight="35"/>
            </VBox>

            <!-- Message -->
            <Label fx:id="notification"
                   style="-fx-font-size: 11; -fx-text-fill: red;"/>

            <!-- Buttons -->
            <HBox spacing="10" alignment="CENTER">
                <!-- ✅ XÓA onAction="#logIn" -->
                <Button fx:id="logInButton"
                        text="🔐 Đăng nhập"
                        style="-fx-padding: 10 40; -fx-font-size: 13;"
                        prefWidth="150"/>
                <!-- ✅ XÓA onAction="#back" -->
                <Button fx:id="backBtn"
                        text="← Quay lại"
                        style="-fx-padding: 10 40; -fx-font-size: 13;"/>
            </HBox>

            <Separator/>

            <Label text="Chưa có tài khoản? Đăng ký ngay!"
                   style="-fx-text-fill: #3498db; -fx-font-size: 11;"/>
        </VBox>
    </center>
</BorderPane>