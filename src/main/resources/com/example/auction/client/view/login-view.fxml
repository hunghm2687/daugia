<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.LoginController"
            style="-fx-font-family: 'Arial'; -fx-font-size: 12;">

    <center>
        <VBox spacing="20"
              style="-fx-padding: 50; -fx-alignment: CENTER; -fx-background-color: #f5f5f5;"
              prefHeight="400" prefWidth="500">

            <Label text="🔐 Đăng Nhập"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #e74c3c; -fx-alignment: CENTER;"/>

            <VBox spacing="5">
                <Label text="Email:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="emailTextField"
                           promptText="Nhập email của bạn"
                           style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mật khẩu:" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Nhập mật khẩu"
                               style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>
            </VBox>

            <Label fx:id="notification"
                   text=""
                   style="-fx-text-fill: red; -fx-font-size: 12;"/>

            <Button fx:id="logInButton"
                    text="Đăng Nhập"
                    style="-fx-padding: 12; -fx-font-size: 14; -fx-cursor: hand; -fx-text-fill: white; -fx-background-color: #e74c3c; -fx-border-radius: 5;"/>

            <Button fx:id="backBtn"
                    text="← Quay lại"
                    style="-fx-padding: 10; -fx-font-size: 12; -fx-cursor: hand; -fx-background-color: white; -fx-border-color: #ddd;"/>
        </VBox>
    </center>
</BorderPane>