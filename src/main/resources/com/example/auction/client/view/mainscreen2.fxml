<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.Main2Controller"
            style="-fx-font-size: 12;">

    <!-- TOP: Header -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10; -fx-spacing: 15;">
            <Label text="🎯 HỆ THỐNG ĐẤU GIÁ"
                   style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="userStatusLabel"
                   text="👤 Bạn chưa đăng nhập"
                   style="-fx-text-fill: #3498db; -fx-font-size: 11;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="loginBtn" text="🔐 Đăng nhập" style="-fx-padding: 8;"/>
            <Button fx:id="signupBtn" text="📝 Đăng ký" style="-fx-padding: 8;"/>
        </HBox>
    </top>

    <!-- CENTER: Search + Products -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <!-- Search Bar -->
            <HBox spacing="10">
                <TextField fx:id="searchField"
                           promptText="Tìm kiếm sản phẩm..."
                           HBox.hgrow="ALWAYS"
                           prefHeight="30"/>
                <Button text="🔍 Tìm" prefWidth="80"/>
            </HBox>

            <!-- Products Grid -->
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <FlowPane fx:id="productsPane"
                          hgap="15"
                          vgap="15"
                          style="-fx-padding: 10;"
                          prefWrapLength="1200"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
