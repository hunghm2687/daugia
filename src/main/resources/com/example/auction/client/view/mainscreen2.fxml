<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.Main2Controller"
            style="-fx-font-family: 'Arial'; -fx-font-size: 12;">

    <!-- ============ TOP: Header ============ -->
    <top>
        <VBox style="-fx-background-color: #f5f5f5; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <!-- Row 1: Logo and Time -->
            <HBox spacing="20" style="-fx-padding: 10; -fx-alignment: CENTER_LEFT;">
                <Label text="🏆 Đấu Giá Online" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userStatusLabel" text="👤 Bạn chưa đăng nhập"
                       style="-fx-font-size: 12; -fx-text-fill: #333;"/>
                <Label fx:id="labelTime" text="00:00:00"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                <Label fx:id="labelDate" text="Thứ, 01/01/2026"
                       style="-fx-font-size: 11; -fx-text-fill: #666;"/>
            </HBox>

            <!-- Row 2: Search and Buttons -->
            <HBox spacing="10" style="-fx-padding: 10; -fx-alignment: CENTER;">
                <TextField fx:id="searchField"
                           promptText="🔍 Tìm kiếm sản phẩm..."
                           prefWidth="400"
                           style="-fx-padding: 8; -fx-font-size: 12; -fx-border-radius: 5; -fx-border-color: #ddd;"/>

                <Button fx:id="loginBtn"
                        text="Đăng nhập"
                        style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand; -fx-border-radius: 5; -fx-border-color: #3498db; -fx-text-fill: #3498db; -fx-background-color: white;"/>

                <Button fx:id="signupBtn"
                        text="Đăng kí"
                        style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand; -fx-border-radius: 5; -fx-border-color: #2ecc71; -fx-text-fill: #2ecc71; -fx-background-color: white;"/>

                <Button fx:id="profileBtn"
                        text="👤 Hồ sơ"
                        disable="true"
                        style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand; -fx-border-radius: 5; -fx-border-color: #9b59b6; -fx-text-fill: #9b59b6; -fx-background-color: white;"/>

                <Button fx:id="createAuctionBtn"
                        text="➕ Tạo phiên"
                        disable="true"
                        style="-fx-padding: 8 20; -fx-font-size: 12; -fx-cursor: hand; -fx-border-radius: 5; -fx-text-fill: white; -fx-background-color: #e74c3c;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ============ CENTER: Product List ============ -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-padding: 0;">
            <FlowPane fx:id="productsPane"
                      hgap="20"
                      vgap="20"
                      style="-fx-padding: 20;"
                      prefWrapLength="1200"/>
        </ScrollPane>
    </center>
</BorderPane>