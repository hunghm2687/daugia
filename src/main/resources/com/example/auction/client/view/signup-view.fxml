<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auction.client.view.SignupController"
            style="-fx-font-family: 'Arial'; -fx-font-size: 12;">

   <center>
      <VBox spacing="15"
            style="-fx-padding: 40; -fx-alignment: CENTER; -fx-background-color: #f5f5f5;"
            prefHeight="500" prefWidth="500">

         <Label text="📝 Đăng Kí Tài Khoản"
                style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2ecc71; -fx-alignment: CENTER;"/>

         <VBox spacing="5">
            <Label text="Username:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="usernameTF"
                       promptText="Chọn username"
                       style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>
         </VBox>

         <VBox spacing="5">
            <Label text="Email:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="emailTF"
                       promptText="Nhập email"
                       style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>
         </VBox>

         <VBox spacing="5">
            <Label text="Mật khẩu (ít nhất 6 ký tự):" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="passwordF"
                           promptText="Nhập mật khẩu"
                           style="-fx-padding: 10; -fx-font-size: 12; -fx-border-radius: 5;"/>
         </VBox>

         <Label fx:id="messageLabel"
                text=""
                style="-fx-text-fill: red; -fx-font-size: 12;"/>

         <Button fx:id="signupBtn"
                 text="Đăng Kí"
                 style="-fx-padding: 12; -fx-font-size: 14; -fx-cursor: hand; -fx-text-fill: white; -fx-background-color: #2ecc71; -fx-border-radius: 5;"/>

         <Button fx:id="backBtn"
                 text="← Quay lại"
                 style="-fx-padding: 10; -fx-font-size: 12; -fx-cursor: hand; -fx-background-color: white; -fx-border-color: #ddd;"/>
      </VBox>
   </center>
</BorderPane>