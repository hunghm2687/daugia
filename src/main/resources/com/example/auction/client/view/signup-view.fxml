<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="signup-background" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.auction.client.view.SignupController">
   <children>
      <TextField fx:id="usernameTF" layoutX="268.0" layoutY="112.0" prefHeight="25.0" prefWidth="134.0" styleClass="text-field" stylesheets="@style.css" />
      <Label alignment="CENTER_RIGHT" layoutX="155.0" layoutY="112.0" prefHeight="30.0" prefWidth="96.0" styleClass="glow-text" stylesheets="@style.css" text="Username" />
      <TextField fx:id="emailTF" layoutX="268.0" layoutY="229.0" prefHeight="39.0" prefWidth="134.0" styleClass="text-field-capsule" stylesheets="@style.css" />
      <Label alignment="CENTER_RIGHT" layoutX="155.0" layoutY="175.0" prefHeight="30.0" prefWidth="96.0" styleClass="glow-text" stylesheets="@style.css" text="Password" />
      <TextField fx:id="passwordF" layoutX="268.0" layoutY="171.0" prefHeight="39.0" prefWidth="134.0" styleClass="text-field-capsule" stylesheets="@style.css" />
      <Label alignment="CENTER_RIGHT" layoutX="155.0" layoutY="233.0" prefHeight="30.0" prefWidth="96.0" styleClass="glow-text" stylesheets="@style.css" text="Email" />
      <Button fx:id="signUpButton" layoutX="278.0" layoutY="312.0" mnemonicParsing="false" onAction="#signUp" styleClass="signup-button" stylesheets="@style.css" text="Sign up" />
      <Label layoutX="240.0" layoutY="41.0" styleClass="signup-label" stylesheets="@style.css" text="Đăng kí">
         <font>
            <Font size="28.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
